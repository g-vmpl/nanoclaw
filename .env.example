# Default model and effort for all agents (used when not set per-agent or in DB).
# CLAUDE_MODEL=claude-sonnet-4-5
# CLAUDE_EFFORT=medium

# Per-agent model/effort overrides — applied at spawn time when not set in DB.
# Key format: AGENT_MODEL_<FOLDER> / AGENT_EFFORT_<FOLDER>
# FOLDER = agent group folder name, uppercased, hyphens replaced with underscores.
#
# Example — agent group folder "ops-with-netra":
# AGENT_MODEL_OPS_WITH_NETRA=claude-opus-4-7
# AGENT_EFFORT_OPS_WITH_NETRA=high
#
# Example — folder "dm-with-netra":
# AGENT_MODEL_DM_WITH_NETRA=claude-haiku-4-5-20251001
# AGENT_EFFORT_DM_WITH_NETRA=low
#
# Valid effort values: low, medium, high
# Model IDs: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001, etc.

# Mention-mode sender whitelists — synced into DB on every startup.
# Key: MENTION_WHITELIST_<mga-id with dashes replaced by underscores>
# Value: comma-separated bare phone numbers (the part between channel: and @)
# '.' or omitting the key = any sender's @mention triggers the agent.
#
# Example — only 918466971926 can trigger netra in Vm sales group:
# MENTION_WHITELIST_mga_1779422057429_77pkfm=918466971926
#
# Add more senders (comma-separated):
# MENTION_WHITELIST_mga_1779422057429_77pkfm=918466971926,919999404525
